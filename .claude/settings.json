{
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(operations/**)",
      "Write(legal/**)",
      "Write(finance/**)",
      "Write(tax/**)",
      "Write(memory/knowledge.jsonl)",
      "Write(memory/backups/**)",
      "Write(memory/archive/**)",
      "Write(documents/comms/**)"
    ],
    "deny": [
      "Write(CLAUDE.md)",
      "Write(.claude/agents/**)",
      "Write(.claude/skills/**)",
      "Write(.claude/settings.json)",
      "Write(documents/contracts/personal/**)",
      "Read(documents/contracts/personal/**)",
      "Delete(**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/safety-guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/session-log.py"
          },
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/lint-check.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/vault-context.py"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/context-recovery.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/verification-gate.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/subagent-context.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python D:/REDPEAK/AgentHQ/.claude/hooks/prompt-enricher.py"
          }
        ]
      }
    ]
  }
}
